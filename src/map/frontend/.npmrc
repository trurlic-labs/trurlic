# ── Supply-chain hardening ───────────────────────────────────────────
#
# These defaults apply to every `npm install` / `npm ci` inside
# this package, whether run locally or in CI.

# Block lifecycle scripts in dependencies.  Most supply-chain attacks
# (e.g. the March 2026 Axios compromise) rely on postinstall hooks
# to execute malicious code during install.  Legitimate build scripts
# (e.g. esbuild, sharp) are not used by this SDK.
ignore-scripts=true

# Reject any package version published less than 7 days ago.
# Closes the window between a compromised publish and community
# detection / registry takedown.
#
# Requires npm >= 11.10.0. Check with: npm --version
# Upgrade with:            npm install -g npm@latest
# Override per-install:    npm install --min-release-age=0
min-release-age=7

# Fail `npm audit` on high-severity or above.
audit-level=high
